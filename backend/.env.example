# inRebus Agency - Backend Environment Configuration
# Copy this file to .env and adjust the values for your environment.

# PostgreSQL connection string (SQLAlchemy synchronous format)
DATABASE_URL=postgresql://inrebus:inrebus@localhost:5432/inrebus_agency

# Sentence-Transformer model identifier (HuggingFace)
# The multilingual MiniLM model supports both Italian and English.
SENTENCE_TRANSFORMER_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Allowed CORS origins for the React development server
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
